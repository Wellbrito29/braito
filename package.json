{
  "name": "braito",
  "version": "0.1.0",
  "description": "AI File Notes — generates operational knowledge sidecars for codebases",
  "type": "module",
  "bin": {
    "ai-notes": "./src/cli/index.ts"
  },
  "scripts": {
    "scan": "bun src/cli/index.ts scan --root .",
    "generate": "bun src/cli/index.ts generate --root .",
    "generate:force": "bun src/cli/index.ts generate --root . --force",
    "generate:dry": "bun src/cli/index.ts generate --root . --dry-run",
    "generate:v": "bun src/cli/index.ts generate --root . --verbose",
    "watch": "bun src/cli/index.ts watch --root .",
    "mcp": "bun src/cli/index.ts mcp --root .",
    "ui": "bun src/cli/index.ts ui --root .",
    "init:agent": "bun src/cli/index.ts init --agent --root .",
    "test": "bun test"
  },
  "dependencies": {
    "minisearch": "^7.2.0",
    "ts-morph": "^25.0.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.90.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
